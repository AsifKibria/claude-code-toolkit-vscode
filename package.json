{
  "name": "claude-code-toolkit",
  "displayName": "Claude Code Toolkit",
  "description": "Health monitoring, session management, and maintenance tools for Claude Code",
  "version": "2.0.1",
  "publisher": "asifkibria",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "maintenance",
    "sessions"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeToolkit.showDashboard",
        "title": "Open Dashboard",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.healthCheck",
        "title": "Health Check",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.searchSessions",
        "title": "Search Conversations",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.refreshSessions",
        "title": "Refresh Sessions",
        "category": "Claude Toolkit",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeToolkit.starSession",
        "title": "Star Session",
        "category": "Claude Toolkit",
        "icon": "$(star-empty)"
      },
      {
        "command": "claudeToolkit.unstarSession",
        "title": "Unstar Session",
        "category": "Claude Toolkit",
        "icon": "$(star-full)"
      },
      {
        "command": "claudeToolkit.exportSession",
        "title": "Export Session",
        "category": "Claude Toolkit",
        "icon": "$(export)"
      },
      {
        "command": "claudeToolkit.archiveSession",
        "title": "Archive Session",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.deleteSession",
        "title": "Delete Session",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.runMaintenance",
        "title": "Run Maintenance",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.securityScan",
        "title": "Security Scan",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.openSession",
        "title": "Open Session",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.addCapTask",
        "title": "Add Prompt to Queue",
        "category": "Claude Toolkit",
        "icon": "$(add)"
      },
      {
        "command": "claudeToolkit.addQuickPrompt",
        "title": "Quick Add Prompt",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.sendPrompt",
        "title": "Copy & Send Prompt",
        "category": "Claude Toolkit",
        "icon": "$(send)"
      },
      {
        "command": "claudeToolkit.editPrompt",
        "title": "Edit Prompt",
        "category": "Claude Toolkit",
        "icon": "$(edit)"
      },
      {
        "command": "claudeToolkit.removePrompt",
        "title": "Remove Prompt",
        "category": "Claude Toolkit",
        "icon": "$(trash)"
      },
      {
        "command": "claudeToolkit.simulateCapReached",
        "title": "Test: Simulate Cap",
        "category": "Claude Toolkit",
        "icon": "$(beaker)"
      },
      {
        "command": "claudeToolkit.setCapResetTime",
        "title": "Set Cap Reset Time",
        "category": "Claude Toolkit",
        "icon": "$(clock)"
      },
      {
        "command": "claudeToolkit.clearCapStatus",
        "title": "Clear Cap Status",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.clearSentPrompts",
        "title": "Clear Sent Prompts",
        "category": "Claude Toolkit"
      },
      {
        "command": "claudeToolkit.refreshUsageCap",
        "title": "Refresh",
        "category": "Claude Toolkit",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeToolkit.fixSession",
        "title": "Fix Oversized Content",
        "category": "Claude Toolkit",
        "icon": "$(wrench)"
      },
      {
        "command": "claudeToolkit.unstickSession",
        "title": "Unstick Session",
        "category": "Claude Toolkit",
        "icon": "$(debug-restart)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-toolkit",
          "title": "Claude Toolkit",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "claude-toolkit": [
        {
          "id": "claudeToolkit.health",
          "name": "Health"
        },
        {
          "id": "claudeToolkit.usageCap",
          "name": "Prompt Queue"
        },
        {
          "id": "claudeToolkit.starred",
          "name": "Starred Sessions"
        },
        {
          "id": "claudeToolkit.sessions",
          "name": "Recent Sessions"
        },
        {
          "id": "claudeToolkit.maintenance",
          "name": "Maintenance"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeToolkit.sessions",
        "contents": "No Claude Code sessions found.\n[Run Health Check](command:claudeToolkit.healthCheck)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeToolkit.refreshSessions",
          "when": "view == claudeToolkit.sessions",
          "group": "navigation"
        },
        {
          "command": "claudeToolkit.addCapTask",
          "when": "view == claudeToolkit.usageCap",
          "group": "navigation"
        },
        {
          "command": "claudeToolkit.refreshUsageCap",
          "when": "view == claudeToolkit.usageCap",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeToolkit.starSession",
          "when": "view == claudeToolkit.sessions && viewItem == session",
          "group": "inline"
        },
        {
          "command": "claudeToolkit.exportSession",
          "when": "viewItem == session || viewItem == starredSession",
          "group": "1_actions"
        },
        {
          "command": "claudeToolkit.archiveSession",
          "when": "viewItem == session || viewItem == starredSession",
          "group": "2_manage"
        },
        {
          "command": "claudeToolkit.deleteSession",
          "when": "viewItem == session",
          "group": "2_manage"
        },
        {
          "command": "claudeToolkit.unstickSession",
          "when": "viewItem == session || viewItem == starredSession",
          "group": "2_manage"
        },
        {
          "command": "claudeToolkit.fixSession",
          "when": "viewItem == session || viewItem == starredSession",
          "group": "2_manage"
        },
        {
          "command": "claudeToolkit.editPrompt",
          "when": "viewItem == queuedPrompt",
          "group": "1_actions"
        },
        {
          "command": "claudeToolkit.removePrompt",
          "when": "viewItem == queuedPrompt",
          "group": "2_manage"
        }
      ]
    },
    "configuration": {
      "title": "Claude Toolkit",
      "properties": {
        "claudeToolkit.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show health status in the status bar"
        },
        "claudeToolkit.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh session list"
        },
        "claudeToolkit.refreshInterval": {
          "type": "number",
          "default": 60,
          "description": "Refresh interval in seconds"
        },
        "claudeToolkit.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications for health issues"
        },
        "claudeToolkit.autoOpenDashboard": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the dashboard in your browser when VS Code starts"
        },
        "claudeToolkit.dashboardPort": {
          "type": "number",
          "default": 1405,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port the dashboard listens on"
        },
        "claudeToolkit.defaultSendTarget": {
          "type": "string",
          "enum": [
            "ask",
            "chat",
            "terminal"
          ],
          "default": "ask",
          "description": "Where queued prompts should be sent. 'chat' pastes into the Claude Code panel; 'terminal' pipes through the claude CLI; 'ask' prompts each time."
        },
        "claudeToolkit.autoDetectCap": {
          "type": "boolean",
          "default": false,
          "description": "Auto-detect Claude Code usage-cap errors by watching ~/.claude/projects/*.jsonl. OFF by default because earlier versions matched on raw conversation content (false positives whenever 'rate limit' or similar phrases appeared in chat). When enabled, only matches inside actual API error structures, scans only newly-appended bytes, and throttles repeat fires to once per 5 minutes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asifkibria/claude-code-toolkit-vscode"
  },
  "license": "MIT"
}
